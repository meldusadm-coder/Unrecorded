# Normalize line endings for cross-platform dev (Windows host + Linux dev container).
* text=auto eol=lf

# Shell scripts must stay LF even on Windows checkouts.
*.sh text eol=lf
*.bash text eol=lf

# Windows-only scripts may use CRLF on the host.
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.keystore binary
